{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/ai-native-site/index.html" },
    { "source": "/agents-in-practice", "destination": "/ai-native-site/agents-in-practice.html" },
    { "source": "/agents-in-practice.html", "destination": "/ai-native-site/agents-in-practice.html" },
    { "source": "/modules/:match", "destination": "/ai-native-site/modules/:match.html" },
    { "source": "/modules/:match.html", "destination": "/ai-native-site/modules/:match.html" },
    { "source": "/css/(.*)", "destination": "/ai-native-site/css/$1" },
    { "source": "/js/(.*)", "destination": "/ai-native-site/js/$1" },
    { "source": "/og.png", "destination": "/ai-native-site/og.png" },
    { "source": "/og-card.html", "destination": "/ai-native-site/og-card.html" }
  ]
}
